@page
@model ClinicScheduler_Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h4 class="mb-4">Dashboard</h4>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow">
                <div class="card-body">
                    <h6 class="card-title">Pacientes</h6>
                    <h2 class="card-text">@Model.TotalPacientes</h2>
                    <a href="/Pacientes" class="text-white text-decoration-none small">Ver todos →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow">
                <div class="card-body">
                    <h6 class="card-title">Profissionais</h6>
                    <h2 class="card-text">@Model.TotalProfissionais</h2>
                    <a href="/Profissionais" class="text-white text-decoration-none small">Ver todos →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-dark shadow">
                <div class="card-body">
                    <h6 class="card-title">Agendas</h6>
                    <h2 class="card-text">@Model.TotalAgendas</h2>
                    <a href="/Agendas" class="text-white text-decoration-none small">Ver todas →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning shadow">
                <div class="card-body">
                    <h6 class="card-title">Agendamentos</h6>
                    <h2 class="card-text">@Model.TotalAgendamentos</h2>
                    <a href="/Agendamento" class="text-white text-decoration-none small">Ver todos →</a>
                </div>
            </div>
        </div>
    </div>
</div>