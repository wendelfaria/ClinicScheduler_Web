@page
@model ClinicScheduler_Web.Pages.AgendasModel
@{
    ViewData["Title"] = "Agendas";
}

<div class="container mt-4">
    <h4>Agendas</h4>

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <label class="form-label">Profissional</label>
                <select name="profissionalId" class="form-select" required>
                    <option value="">Selecione...</option>
                    @foreach (var p in Model.Profissionais)
                    {
                        <option value="@p.Id">@p.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Data</label>
                <input type="date" name="data" class="form-control" required />
            </div>
            <div class="col-md-2">
                <label class="form-label">Início</label>
                <input type="time" name="horaInicio" class="form-control" required />
            </div>
            <div class="col-md-2">
                <label class="form-label">Fim</label>
                <input type="time" name="horaFim" class="form-control" required />
            </div>
            <div class="col-md-2">
                <label class="form-label">Intervalo (min)</label>
                <input type="number" name="intervaloMinutos" class="form-control" value="30" min="5" required />
            </div>
        </div>
        <div class="row g-3 mb-3 align-items-center">
            <div class="col-auto">
                <div class="form-check">
                    <input type="checkbox" name="temAlmoco" value="true" class="form-check-input" id="chkAlmoco"
                           onclick="toggleAlmoco()" />
                    <label class="form-check-label" for="chkAlmoco">Pausa de almoço</label>
                </div>
            </div>
            <div class="col-md-2" id="divAlmoco" style="display:none">
                <label class="form-label">Duração (min)</label>
                <input type="number" name="duracaoAlmoco" id="duracaoAlmoco" class="form-control" value="60" min="15" />
            </div>
            <div class="col-md-2 ms-auto">
                <button type="submit" class="btn btn-primary w-100">Criar Agenda</button>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert @(Model.Mensagem.Contains("sucesso") ? "alert-success" : "alert-danger")">
            @Model.Mensagem
        </div>
    }

    <hr />

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Profissional</th>
                <th>Data</th>
                <th>Início</th>
                <th>Fim</th>
                <th>Intervalo</th>
                <th>Almoço</th>
                <th>Ação</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Agendas)
            {
                <tr>
                    <td>@a.Id</td>
                    <td>@a.Profissional?.Nome</td>
                    <td>@a.Data.ToString("dd/MM/yyyy")</td>
                    <td>@a.HoraInicio.ToString("HH:mm")</td>
                    <td>@a.HoraFim.ToString("HH:mm")</td>
                    <td>@a.IntervaloMinutos min</td>
                    <td>@(a.TemAlmoco ? $"{a.DuracaoAlmoco} min" : "Não")</td>
                    <td>
                        <form method="post" action="/Agendas?handler=Excluir" onsubmit="return confirm('Excluir esta agenda e todos os horários?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="agendaId" value="@a.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Excluir</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function toggleAlmoco() {
        const div = document.getElementById('divAlmoco');
        const chk = document.getElementById('chkAlmoco');
        div.style.display = chk.checked ? '' : 'none';
    }
</script>