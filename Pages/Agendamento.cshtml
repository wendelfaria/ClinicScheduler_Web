@page
@model ClinicScheduler_Web.Pages.AgendamentoModel
@{
    ViewData["Title"] = "Agendamento";
}

<div class="container mt-4">
    <h4>Agendamento</h4>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Profissional</label>
            <select id="selProfissional" class="form-select" onchange="carregarAgendas()">
                <option value="">Selecione...</option>
                @foreach (var p in Model.Profissionais)
                {
                    <option value="@p.Id">@p.Nome</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Agenda</label>
            <select id="selAgenda" class="form-select" onchange="carregarHorarios()">
                <option value="">Selecione...</option>
            </select>
        </div>
    </div>

    <div id="divHorarios" style="display:none">
        <h5 class="mb-3">Horários</h5>
        <div id="listaHorarios" class="row g-2"></div>
    </div>

    <!-- Modal de agendamento -->
    <div class="modal fade" id="modalAgendar" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo">Agendar Paciente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="horarioId" id="inputHorarioId" />
                    <input type="hidden" name="agendaId" id="inputAgendaId" />
                    <div class="modal-body">
                        <label class="form-label">Paciente</label>
                        <select name="pacienteId" class="form-select" required>
                            <option value="">Selecione...</option>
                            @foreach (var p in Model.Pacientes)
                            {
                                <option value="@p.Id">@p.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Confirmar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensagem))
    {
        <div class="alert @(Model.Mensagem.Contains("sucesso") ? "alert-success" : "alert-danger") mt-3">
            @Model.Mensagem
        </div>
    }
</div>
<!-- Menu de contexto -->
<div id="menuContexto" style="display:none; position:absolute; z-index:1000; background:white; border:1px solid #ccc; border-radius:4px; box-shadow: 2px 2px 6px rgba(0,0,0,0.2);">
    <div class="list-group list-group-flush">
        <button id="btnConfirmado" class="list-group-item list-group-item-action text-success" onclick="alterarStatus('confirmado')">✅ Confirmado</button>
        <button id="btnCancelado" class="list-group-item list-group-item-action text-warning" onclick="alterarStatus('cancelado')">⚠️ Cancelado</button>
        <button id="btnFalta" class="list-group-item list-group-item-action text-danger" onclick="alterarStatus('falta')">❌ Falta</button>
        <button id="btnBloquear" class="list-group-item list-group-item-action text-dark" onclick="alterarStatus('bloqueado')">🔒 Bloquear</button>
    </div>
</div>

<!-- Formulário oculto de status -->
<form method="post" asp-page-handler="AlterarStatus" id="formStatus">
    @Html.AntiForgeryToken()
    <input type="hidden" name="horarioId" id="inputStatusHorarioId" />
    <input type="hidden" name="novoStatus" id="inputNovoStatus" />
</form>
<script>
    async function carregarAgendas() {
        const profId = document.getElementById('selProfissional').value;
        const sel = document.getElementById('selAgenda');
        sel.innerHTML = '<option value="">Selecione...</option>';
        document.getElementById('divHorarios').style.display = 'none';
        if (!profId) return;

        const resp = await fetch(`/api/agendas?profissionalId=${profId}`);
        const agendas = await resp.json();
        agendas.forEach(a => {
            const opt = document.createElement('option');
            opt.value = a.id;
            opt.text = a.data;
            sel.appendChild(opt);
        });
    }

    async function carregarHorarios() {
        const agendaId = document.getElementById('selAgenda').value;
        if (!agendaId) return;

        const resp = await fetch(`/api/horarios?agendaId=${agendaId}`);
        const horarios = await resp.json();

        const lista = document.getElementById('listaHorarios');
        lista.innerHTML = '';

        horarios.forEach(h => {
            const cor = h.status === 'disponivel' ? 'btn-outline-success' :
                        h.status === 'agendado' ? 'btn-primary' :
                        h.status === 'confirmado' ? 'btn-success' :
                        h.status === 'cancelado' ? 'btn-warning' :
                        h.status === 'falta' ? 'btn-danger' :
                        h.status === 'bloqueado' ? 'btn-dark' : 'btn-secondary';

            const texto = h.status === 'bloqueado' ? `${h.hora} 🔒 ${h.observacaoBloqueio}` :
                          h.paciente ? `${h.hora} — ${h.paciente}` : h.hora;

            lista.innerHTML += `
                <div class="col-auto">
                    <button type="button" class="btn ${cor}"
                        onclick="abrirModal(${h.id}, '${h.hora}', '${h.status}', ${agendaId})"
                        oncontextmenu="abrirContexto(event, ${h.id}, '${h.status}')">
                        ${texto}
                    </button>
                </div>`;
        });

        document.getElementById('divHorarios').style.display = '';
    }

    function abrirModal(horarioId, hora, status, agendaId) {
        if (status === 'bloqueado') return;
        if (status !== 'disponivel') return;
        document.getElementById('inputHorarioId').value = horarioId;
        document.getElementById('inputAgendaId').value = agendaId;
        document.getElementById('modalTitulo').innerText = `Agendar — ${hora}`;
        new bootstrap.Modal(document.getElementById('modalAgendar')).show();
    }

    function abrirContexto(event, horarioId, status) {
        event.preventDefault();
        const menu = document.getElementById('menuContexto');
        menu.style.display = 'block';
        menu.style.left = event.pageX + 'px';
        menu.style.top = event.pageY + 'px';

        document.getElementById('btnConfirmado').style.display = status === 'agendado' || status === 'confirmado' ? '' : 'none';
        document.getElementById('btnCancelado').style.display = status === 'agendado' || status === 'confirmado' ? '' : 'none';
        document.getElementById('btnFalta').style.display = status === 'agendado' || status === 'confirmado' ? '' : 'none';
        document.getElementById('btnBloquear').style.display = status === 'disponivel' ? '' : 'none';

        document.getElementById('inputStatusHorarioId').value = horarioId;
    }

    document.addEventListener('click', () => {
        document.getElementById('menuContexto').style.display = 'none';
    });

    function alterarStatus(novoStatus) {
        document.getElementById('inputNovoStatus').value = novoStatus;
        document.getElementById('formStatus').submit();
    }
</script>